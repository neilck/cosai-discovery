# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit it.

# Anthropic API key for LLM-driven classification (Stage 1).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model for Stage 1.
# Default: claude-haiku-4-5
# CDX_MODEL=claude-haiku-4-5

# Optional: override the default model for later stages that may need stronger reasoning.
# Default: claude-sonnet-4-6
# CDX_MODEL_STRONG=claude-sonnet-4-6
